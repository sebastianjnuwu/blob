{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineEnding": "lf",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true
  },
  "files": {
    "includes": [
      "**",
      "**/*.ts",
      "!node_modules",
      "!dist",
      "!build",
      "!.astro",
      "!out",
      "!coverage",
      "!**/*.d.ts"
    ]
  }
}
