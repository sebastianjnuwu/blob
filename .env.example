# Server 
BLOB_PORT=3000
BLOB_HOST=localhost

# Database URL (e.g., postgres://user:password@host:port/dbname)
DATABASE_URL=

# Redis URL (e.g., redis://localhost:6379)
REDIS_URL=

# Path where uploaded files will be stored (relative to the project root)
# Default is "storage/uploads".
# Example: (e.g storage/uploads)
BLOB_STORAGE_PATH=storage/uploads

# Secret key for signing JWT tokens (must be at least 32 characters long)
# Default is "change-me-with-32-characters-or-more".
# Example: (e.g change-me-with-32-characters-or-more)
BLOB_TOKEN_SECRET=change-me-with-32-characters-or-more

# Download rate limiting (requests per window)
# Default is 120 requests per window.
# Example: (e.g 120 for 120 requests per window)
BLOB_RATE_LIMIT_MAX=120

# Time window for download rate limiting in milliseconds (e.g., 60000 for 1 minute)
# Default is 60000 ms (1 minute).
# Example: (e.g 60000 for 1 minute)
BLOB_RATE_LIMIT_WINDOW_MS=60000

# Allowed MIME types for upload (comma-separated)
# Default is "image/png,image/jpeg,image/gif,image/webp". 
# Example: (e.g image/png,image/jpeg,image/gif,image/webp)
BLOB_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/gif,image/webp

# Optional: set a maximum upload size (in bytes) to prevent abuse (e.g., 10MB = 10485760 bytes)
# Default is 100MB.
# Example: (e.g 104.857.600 for 100MB)
BLOB_MAX_UPLOAD_SIZE_BYTES=104857600

# Optional: set a maximum total storage size (in bytes) to prevent disk overflow (e.g., 1GB = 1073741824 bytes)
# Default is 1GB.
# Example: (e.g 1073741824 for 1GB)
BLOB_MAX_STORAGE_SIZE=1073741824

# Optional: enable CORS and specify allowed origins (comma-separated)
# Default is "*" to allow all origins.
# Example: (e.g http://localhost:3000,http://example.com)
BLOB_CORS_ORIGINS=http://localhost:3000

# Interval to run the cleanup task that deletes expired blobs
# Accepts Go duration format (e.g. 30s, 10m, 24h, 7d)
# Default: 24h
# Example: (e.g 30s for every 30 seconds, 24h for every 24 hours)
BLOB_EXPIRED_CLEANUP_INTERVAL=24h